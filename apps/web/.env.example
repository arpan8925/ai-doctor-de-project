# --- AI Doctor — web environment template ---
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Backend URL. Defaults to http://localhost:8000 if unset.
# In Vercel: set this to your Render URL, e.g. https://ai-doctor-api.onrender.com
VITE_API_BASE=http://localhost:8000

# Firebase web config — safe to expose in the bundle (these are public IDs).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
