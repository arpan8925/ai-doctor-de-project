# --- AI Doctor — backend environment template ---
# Copy this file to `.env` for local dev (`.env` is gitignored).
# In hosted envs (Render/Fly/etc.), set these as platform env vars instead.

# Thesys C1 (generative UI). https://console.thesys.dev/
THESYS_API_KEY=
THESYS_API_BASE=https://api.thesys.dev/v1/embed
THESYS_MODEL=c1/anthropic/claude-3.5-sonnet/v-20241022

# Google Gemini — reasoning + vision + embeddings.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-2.0-flash

# Optional fallbacks routed via LiteLLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Firebase Admin — for hosted deploys, paste the entire service-account JSON
# as a single-line string here. Locally, leave blank and keep the JSON file at
# apps/api/firebase-service-account.json (gitignored).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated list of allowed frontend origins (no trailing slash).
# Local dev defaults to Vite ports if unset.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEBUG=true
