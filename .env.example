# --- AI Doctor — environment template ---
# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Google Gemini — primary LLM (reasoning, narrowing, embeddings).
# Free tier API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-2.0-flash

# Optional: alternative providers reachable via LiteLLM. Leave blank if not used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DEBUG=true
